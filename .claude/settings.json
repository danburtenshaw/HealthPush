{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(xcodegen)",
      "Bash(xcodegen:*)",
      "Bash(xcodebuild build:*)",
      "Bash(xcodebuild test:*)",
      "Bash(xcodebuild -list:*)",
      "Bash(xcodebuild -showsdks:*)",
      "Bash(xcrun devicectl:*)",
      "Bash(xcrun simctl list:*)",
      "Bash(swift build:*)",
      "Bash(swift test:*)",
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(bundle exec fastlane:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/xcodegen-regen.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "claude-code-setup@claude-plugins-official": true,
    "context7@claude-plugins-official": true
  }
}
