root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{yml,yaml,json,md,mdx,toml}]
indent_size = 2

[Makefile]
indent_style = tab

[*.swift]
indent_size = 4
max_line_length = 120

[*.py]
indent_size = 4
max_line_length = 100

[*.{html,css,js,ts,tsx}]
indent_size = 2
